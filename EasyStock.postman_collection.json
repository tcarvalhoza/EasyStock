                                "value": "application/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/products/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "products",
                                "1"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"price\": 2799.99,\n  \"is_active\": false\n}"
                        }
                    },
                    "response": []
                },
                {
                    "name": "Delete",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/products/1",
                            "host": [
