                            ],
                            "path": [
                                "products",
                                "1"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Update Stock",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/products/1/stock",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "products",
                                "1",
                                "stock"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"quantity\": 20\n}"
                        }
                    },
                    "response": []
                }
            ]
        },
